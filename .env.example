# 🧰 SAT ASSIST 2026 - Environment Variables
# Copy this file to .env and fill in your values
# DO NOT commit .env to git (add to .gitignore)

# ============================================================================
# GOOGLE APPS SCRIPT CONFIGURATION
# ============================================================================

# Script ID from Google Apps Script project
# Get it from: Tools → Project Settings → Script ID
SCRIPT_ID=

# Google Cloud Project ID (optional, for advanced features)
PROJECT_ID=

# ============================================================================
# GITHUB CONFIGURATION
# ============================================================================

# GitHub repository URL
# Format: https://github.com/username/repository or username/repository
GITHUB_REPO=

# Git branch for deployment
GIT_BRANCH=main

# GitHub token (optional, for CI/CD)
GITHUB_TOKEN=

# ============================================================================
# DEPLOYMENT CONFIGURATION
# ============================================================================

# Deployment environment (dev, staging, production)
ENVIRONMENT=dev

# Enable automatic backups (true/false)
AUTO_BACKUP=true

# Backup directory
BACKUP_DIR=./backups

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Project name
PROJECT_NAME=SAT-ASSIST

# Version
VERSION=2026.02

# ============================================================================
# CLASP CONFIGURATION
# ============================================================================

# Path to clasp executable (default: clasp from PATH)
CLASP_PATH=clasp

# Enable verbose logging (true/false)
VERBOSE=false
